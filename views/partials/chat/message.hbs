{{#unless replaceId}}
<div hx-swap-oob="beforeend:#messages">
{{/unless}}
{{#if (isEqual a=role b="user")}}
    <div id="entry-{{id}}" class="flex items-start self-end py-4 my-4">
        <div class="bg-gray-700 text-gray-100 p-3 rounded-xl max-w-lg">{{content}}</div>
    </div>
{{else}}
    {{#if replaceId}}
    <div id="entry-{{id}}" hx-swap-oob="outerHTML:#entry-{{replaceId}}" class="flex flex-col self-start py-4 my-4">
    {{else}}
    <div id="entry-{{id}}" class="flex flex-col self-start py-4 my-4">
    {{/if}}
        <div class="flex w-full">
            <div class="markdown text-gray-100">{{#markdown md=content}}{{/markdown}}</div>
        </div>
    </div>
{{/if}}
{{#unless replaceId}}
</div>
{{/unless}}
