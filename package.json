{
  "name": "redis-js-starter",
  "version": "0.1.0",
  "main": "server/index.js",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "deploy:css": "bunx @tailwindcss/cli -i ./styles/styles.css -o ./public/styles.css",
    "deploy:build": "bun build --target=bun . --outdir build/",
    "dev": "bun run dev.ts",
    "dev:server": "bun run --watch .",
    "dev:css": "bunx @tailwindcss/cli -i ./styles/styles.css -o ./public/styles.css --watch",
    "docker": "docker compose up --env-file .env.docker -d --build",
    "docker:redis": "docker compose up -d redis",
    "format": "prettier . --write",
    "start": "bun .",
    "ts": "bunx tsc"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.70",
    "@ai-sdk/google-vertex": "^3.0.116",
    "@ai-sdk/openai": "^2.0.98",
    "@ai-sdk/rsc": "^1.0.151",
    "agent-memory-client": "^0.3.1",
    "ai": "^5.0.149",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.6",
    "express-session": "^1.19.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "marked": "^17.0.4",
    "redis": "^5.11.0",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express-session": "^1.18.2",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "@types/bun": "^1.3.10"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
